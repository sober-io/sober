#!/usr/bin/env bash
# Pre-commit hook: verify formatting for staged files
# Rust → cargo fmt --check | Frontend → prettier --check
# Quiet on success — only prints on failure.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

STAGED_RS="$(git diff --cached --name-only --diff-filter=ACM -- '*.rs')"
STAGED_FE="$(git diff --cached --name-only --diff-filter=ACM -- '*.svelte' '*.ts' '*.js' '*.css' '*.html')"

FAILED=0

if [ -n "$STAGED_RS" ]; then
    if ! (cd "$REPO_ROOT/backend" && cargo fmt --check -q) >/dev/null 2>&1; then
        echo "pre-commit: Rust formatting check failed. Run 'cargo fmt' in backend/." >&2
        FAILED=1
    fi
fi

if [ -n "$STAGED_FE" ]; then
    FE_FILES=""
    for file in $STAGED_FE; do
        rel="${file#frontend/}"
        if [ "$rel" != "$file" ]; then
            FE_FILES="$FE_FILES $REPO_ROOT/$file"
        fi
    done
    if [ -n "$FE_FILES" ]; then
        if ! (cd "$REPO_ROOT/frontend" && npx prettier --check $FE_FILES) >/dev/null 2>&1; then
            echo "pre-commit: Frontend formatting check failed. Run 'pnpm format' in frontend/." >&2
            FAILED=1
        fi
    fi
fi

exit $FAILED
