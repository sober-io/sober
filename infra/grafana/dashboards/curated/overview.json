      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(sober_agent_requests_total[$__rate_interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sober_agent_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95 latency",
          "refId": "B"
        }
      ],
      "title": "Agent Request Rate & Latency (p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
