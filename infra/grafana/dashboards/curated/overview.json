          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "expr": "sum(rate(sober_llm_tokens_output_total[$__rate_interval])) * 60",
          "legendFormat": "tokens/min",
          "refId": "B"
        }
      ],
      "title": "LLM Latency (p95) & Tokens/min",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
