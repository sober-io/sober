FROM node:24-slim AS frontend-builder
RUN corepack enable
WORKDIR /build/frontend
COPY frontend/package.json frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY frontend/ ./
RUN pnpm build

FROM rust:latest AS backend-builder
RUN apt-get update && apt-get install -y --no-install-recommends protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY backend/ backend/
# Copy frontend build so rust-embed can embed the files.
COPY --from=frontend-builder /build/frontend/build/ frontend/build/
RUN cd backend && cargo build --release -p sober-web

FROM debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN useradd --system --no-create-home --shell /usr/sbin/nologin sober
COPY --from=backend-builder /build/backend/target/release/sober-web /usr/local/bin/sober-web
# Also copy static files for STATIC_DIR override (optional, can use embedded instead).
COPY --from=frontend-builder /build/frontend/build /opt/sober/data/static/
USER sober
ENTRYPOINT ["sober-web"]
