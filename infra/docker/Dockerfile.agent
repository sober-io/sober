FROM rust:latest AS builder
RUN apt-get update && apt-get install -y --no-install-recommends protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY backend/ backend/
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/build/backend/target,id=sober-agent-target \
    cd backend && cargo build --release -p sober-agent \
    && cp target/release/sober-agent /usr/local/bin/sober-agent

FROM debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates bubblewrap iputils-ping curl git \
    clang lld \
    && rm -rf /var/lib/apt/lists/*
# Rust toolchain for WASM plugin compilation (generate-plugin tool).
# RUSTUP_HOME is system-wide (read-only toolchain + targets).
# CARGO_HOME is per-user (writable registry cache + build artifacts).
ENV RUSTUP_HOME=/usr/local/rustup
ENV PATH="/usr/local/rustup/toolchains/stable-x86_64-unknown-linux-gnu/bin:/usr/local/cargo-bin:${PATH}"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal \
    && rustup target add wasm32-wasip1 \
    && cp /usr/local/cargo/bin/* /usr/local/cargo-bin/ 2>/dev/null; mkdir -p /usr/local/cargo-bin \
    && cp /usr/local/cargo/bin/cargo /usr/local/cargo-bin/ \
    && cp /usr/local/cargo/bin/rustc /usr/local/cargo-bin/ 2>/dev/null || true \
    && chmod -R a+rX ${RUSTUP_HOME} /usr/local/cargo-bin \
    && rm -rf /usr/local/cargo
RUN useradd --system --create-home --shell /usr/sbin/nologin sober
ENV CARGO_HOME=/home/sober/.cargo
COPY --from=builder /usr/local/bin/sober-agent /usr/local/bin/sober-agent
RUN mkdir -p /run/sober /var/lib/sober/workspaces/default /home/sober/.cargo \
    && chown -R sober:sober /run/sober /var/lib/sober /home/sober
USER sober
ENTRYPOINT ["sober-agent"]
