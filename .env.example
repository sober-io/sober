# =============================================================================
# Sober — Environment Configuration
# =============================================================================
# Copy to .env and fill in values. Never commit .env.

# -- Environment ---------------------------------------------------------------
# "development" (pretty logs) or "production" (JSON logs)
SOBER_ENV=development

# -- Database ------------------------------------------------------------------
DATABASE_URL=postgres://sober:sober@localhost:5432/sober
DATABASE_MAX_CONNECTIONS=10

# -- Vector Database -----------------------------------------------------------
QDRANT_URL=http://localhost:6334
# QDRANT_API_KEY=

# -- API Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=3000
ADMIN_SOCKET_PATH=/run/sober/admin.sock

# -- LLM (OpenAI-compatible endpoint) -----------------------------------------
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4
LLM_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-3-small

# -- Search (SearXNG) ---------------------------------------------------------
SEARXNG_URL=http://localhost:8080

# -- Logging -------------------------------------------------------------------
RUST_LOG=info

# -- Sessions ------------------------------------------------------------------
SESSION_SECRET=change-me-in-production
SESSION_TTL_SECONDS=2592000

# -- OpenTelemetry (optional) --------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=sober-api

# -- Scheduler -----------------------------------------------------------------
SCHEDULER_TICK_INTERVAL_SECS=60
SCHEDULER_AGENT_SOCKET_PATH=/run/sober/agent.sock
SCHEDULER_ADMIN_SOCKET_PATH=/run/sober/scheduler-admin.sock
SCHEDULER_MAX_CONCURRENT_JOBS=10

# -- MCP -----------------------------------------------------------------------
MCP_REQUEST_TIMEOUT_SECS=30
MCP_MAX_CONSECUTIVE_FAILURES=3
MCP_IDLE_TIMEOUT_SECS=300

# -- Memory --------------------------------------------------------------------
MEMORY_DECAY_HALF_LIFE_DAYS=30
MEMORY_RETRIEVAL_BOOST=0.2
MEMORY_PRUNE_THRESHOLD=0.1

# -- Frontend ------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:3000
